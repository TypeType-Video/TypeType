  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "knip": "^6.11.0",
    "sherif": "^1.11.1"
  },
  "overrides": {
    "picomatch": "^2.3.2"
  },
  "packageManager": "bun@1.3.12",
