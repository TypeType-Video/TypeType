{
  "name": "typetype",
  "version": "1.0.2",
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "knip": "^6.25.0",
    "sherif": "^1.13.0"
  },
  "overrides": {
    "@babel/core": "^7.29.7",
    "picomatch": "^2.3.2"
  },
  "packageManager": "bun@1.3.14",
  "private": true,
  "scripts": {
    "dev": "bun run --cwd apps/web dev",
    "build": "bun run --cwd apps/web build",
    "check": "biome check .",
    "format": "biome format --write .",
    "knip": "knip",
    "sherif": "sherif",
    "test": "bun run --cwd apps/web test",
    "test:coverage": "bun run --cwd apps/web test:coverage"
  },
  "workspaces": [
    "apps/*"
  ]
}
