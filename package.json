{
  "name": "typetype",
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "knip": "^6.23.0",
    "sherif": "^1.12.0"
  },
  "overrides": {
    "@babel/core": "^7.29.7",
    "picomatch": "^2.3.2"
  },
  "packageManager": "bun@1.3.14",
  "private": true,
  "scripts": {
    "dev": "bun run --cwd apps/web dev",
    "build": "bun run --cwd packages/mse build && bun run --cwd apps/web build",
    "check": "biome check .",
    "format": "biome format --write .",
    "knip": "knip",
    "sherif": "sherif",
    "test": "bun run --cwd packages/mse test",
    "test:coverage": "bun run --cwd packages/mse test:coverage"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
