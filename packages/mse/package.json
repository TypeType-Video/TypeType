{
  "name": "@typetype/mse",
  "version": "0.1.0",
  "description": "MSE playback engine for TypeType",
  "license": "MIT",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun run build:types && bun build src/index.ts --target browser --format esm --outfile dist/index.js",
    "build:types": "tsc --emitDeclarationOnly",
    "check": "biome check . && tsc --noEmit",
    "format": "biome format --write .",
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "typescript": "~6.0.3"
  }
}
